---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import NavHub from '../components/NavHub.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  nav?: 'full' | 'hub' | 'none';
  footer?: 'full' | 'none';
  pathSuffix?: string;
  showHubs?: boolean;
  schema?: Record<string, unknown>;
}

const { lang, title, description, nav = 'full', footer = 'full', pathSuffix = '', showHubs = true, schema } = Astro.props;
const t = useTranslations(lang);
const pageTitle = title ?? t('meta.home.title');
const pageDescription = description ?? t('meta.home.description');

const localePath = (l: string) => l === 'fr' ? `/${pathSuffix}` : `/${l}/${pathSuffix}`;
const absUrl = (path: string) => new URL(path, Astro.site).toString();

const canonical = absUrl(localePath(lang));
const ogImage = absUrl('/og-image.jpg');
const ogLocaleMap: Record<Lang, string> = { fr: 'fr_BE', nl: 'nl_BE', en: 'en_US', de: 'de_DE' };

const alt = [
  { lang: 'fr', href: absUrl(localePath('fr')) },
  { lang: 'nl', href: absUrl(localePath('nl')) },
  { lang: 'en', href: absUrl(localePath('en')) },
  { lang: 'de', href: absUrl(localePath('de')) },
];

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  url: canonical,
  name: pageTitle,
  description: pageDescription,
  isPartOf: { '@id': 'https://maurisson.com/#website' },
  about: { '@id': 'https://maurisson.com/#maxime' },
  inLanguage: lang,
};

const lodgingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BedAndBreakfast',
  '@id': 'https://maurisson.com/room#lodging',
  name: 'Chez Maurisson',
  url: 'https://maurisson.com/room',
  image: ogImage,
  description: pageDescription,
  provider: { '@id': 'https://maurisson.com/#maxime' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Herve',
    addressRegion: 'Liège',
    addressCountry: 'BE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 50.638,
    longitude: 5.799,
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.91',
    reviewCount: '62',
    bestRating: '5',
    worstRating: '1',
  },
  priceRange: '€€',
  sameAs: ['https://airbnb.be/h/maurisson'],
};
const pageSchemas = [
  webPageSchema,
  ...(schema ? [schema] : pathSuffix === 'room' ? [lodgingSchema] : []),
];

// Graphe de marque « Maurisson » — entité canonique référencée par @id depuis les apps
// (idées, Green Hub, Music Hub). Permet à Google et aux IA de comprendre que Maurisson
// publie un univers d'OUTILS WEB GRATUITS. Émis sur toutes les pages.
const MAURISSON_APPS = [
  { name: 'Music Hub', url: 'https://musichub.maurisson.com', cat: 'MusicApplication', desc: "Carnet d'accords avec piano, Spotify et studio MIDI." },
  { name: 'Green Hub', url: 'https://greenhub.maurisson.com', cat: 'LifestyleApplication', desc: 'Carnet de jardin : fiches de soin et calendrier par plante.' },
  { name: 'Idées', url: 'https://idees.maurisson.com', cat: 'ProductivityApplication', desc: 'Capture tes idées à la voix, un agent les range pour toi.' },
];
const brandGraph = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': 'https://maurisson.com/#maxime',
    name: 'Maxime Kleinkenberg',
    alternateName: 'Maurisson',
    url: 'https://maurisson.com',
    image: 'https://maurisson.com/apple-touch-icon.png',
    description: "Maurisson publie des outils web gratuits — Music Hub, Green Hub, Idées — et tient la chambre d'hôtes Chez Maurisson à Herve (Belgique).",
    sameAs: ['https://github.com/max7470'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': 'https://maurisson.com/#website',
    name: 'Maurisson',
    url: 'https://maurisson.com',
    publisher: { '@id': 'https://maurisson.com/#maxime' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Outils gratuits Maurisson',
    itemListElement: MAURISSON_APPS.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': ['WebApplication', 'SoftwareApplication'],
        '@id': a.url + '/#app',
        name: a.name,
        url: a.url,
        applicationCategory: a.cat,
        operatingSystem: 'Web',
        description: a.desc,
        offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR', availability: 'https://schema.org/InStock' },
        publisher: { '@id': 'https://maurisson.com/#maxime' },
        isPartOf: { '@id': 'https://maurisson.com/#website' },
      },
    })),
  },
];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="theme-color" content="#0b0907" />
  <meta name="robots" content="index, follow" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Maurisson" />
  <meta property="og:locale" content={ogLocaleMap[lang]} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:alt" content={pageTitle} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  {alt.map(a => (
    <link rel="alternate" hreflang={a.lang} href={a.href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={absUrl(localePath('fr'))} />

  {pageSchemas.map((node) => (
    <script type="application/ld+json" set:html={JSON.stringify(node)} />
  ))}
  {brandGraph.map((node) => (
    <script type="application/ld+json" set:html={JSON.stringify(node)} />
  ))}

  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-56YBF3Q9FN"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-56YBF3Q9FN', { cookie_domain: '.maurisson.com', cookie_flags: 'SameSite=None;Secure' });
    document.addEventListener('click', function (event) {
      var target = event.target;
      var link = target && target.closest ? target.closest('a[href]') : null;
      if (!link) return;

      try {
        var destination = new URL(link.href, location.href);
        var isMaurissonHub = destination.hostname.endsWith('.maurisson.com')
          && destination.hostname !== location.hostname;
        var isAirbnb = destination.hostname === 'airbnb.com'
          || destination.hostname.endsWith('.airbnb.com')
          || destination.hostname === 'airbnb.be'
          || destination.hostname.endsWith('.airbnb.be');
        if (!isMaurissonHub && !isAirbnb) return;

        gtag('event', 'select_content', {
          content_type: 'hub_destination',
          item_id: destination.hostname,
          link_url: destination.href,
        });
      } catch (error) {
        // Analytics must never block navigation.
      }
    });
  </script>
</head>
<body>
  {nav === 'none' ? null : nav === 'hub' ? <NavHub lang={lang} /> : <Nav lang={lang} showHubs={showHubs} />}
  <main>
    <slot />
  </main>
  {footer === 'none' ? null : <Footer lang={lang} />}

  <script>
    // ── Reveal on scroll ─────────────────────────────────────
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.12, rootMargin: '0px 0px -5% 0px' });

    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // ── Nav state on scroll ─────────────────────────────────
    const nav = document.querySelector('[data-nav]');
    let last = 0;
    const onScroll = () => {
      const y = window.scrollY;
      if (nav) {
        nav.classList.toggle('scrolled', y > 40);
      }
      last = y;
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // ── Mobile menu ─────────────────────────────────────────
    const burger = document.querySelector('[data-burger]');
    const menu = document.querySelector('[data-menu]');
    burger?.addEventListener('click', () => {
      const open = menu?.classList.toggle('open');
      burger.setAttribute('aria-expanded', String(!!open));
      document.body.style.overflow = open ? 'hidden' : '';
    });
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      menu.classList.remove('open');
      document.body.style.overflow = '';
      burger?.setAttribute('aria-expanded', 'false');
    }));
  </script>
</body>
</html>
