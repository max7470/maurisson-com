---
import { useTranslations, type Lang, AIRBNB_URL, MUSIC_HUB_URL, languages } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const prefix = lang === 'fr' ? '' : '/' + lang;
const links = [
  { href: prefix + '/#room', label: t('nav.room') },
  { href: prefix + '/#house', label: t('nav.house') },
  { href: prefix + '/#region', label: t('nav.region') },
  { href: prefix + '/#host', label: t('nav.host') },
  { href: prefix + '/#reviews', label: t('nav.reviews') },
];

const langHref = (l: string) => l === 'fr' ? '/' : '/' + l + '/';
---
<nav data-nav>
  <div class="nav-inner">
    <a href={prefix + '/'} class="brand" aria-label="Chez Maurisson">
      <span class="brand-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 11.5 12 4l9 7.5"/>
          <path d="M5 10v10h14V10"/>
          <path d="M10 20v-6h4v6"/>
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-chez">Chez</span>
        <span class="brand-name">Maurisson</span>
      </span>
    </a>

    <ul class="nav-links">
      {links.map(l => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>

    <div class="nav-actions">
      <div class="lang-switch" aria-label={t('lang.switch')}>
        {Object.entries(languages).map(([code, label]) => (
          <a
            href={langHref(code)}
            class={'lang' + (lang === code ? ' active' : '')}
            aria-current={lang === code ? 'page' : undefined}
          >{label}</a>
        ))}
      </div>
      <div class="cta-stack">
        <a href={AIRBNB_URL} target="_blank" rel="noopener" class="btn btn--primary btn--sm">{t('nav.book')}</a>
        <a href={MUSIC_HUB_URL} target="_blank" rel="noopener" class="btn btn--ghost btn--sm cta-music" aria-label={t('nav.music')}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 18V5l12-2v13"/>
            <circle cx="6" cy="18" r="3"/>
            <circle cx="18" cy="16" r="3"/>
          </svg>
          <span>{t('nav.music')}</span>
        </a>
      </div>
      <button class="burger" data-burger aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" data-menu>
    <ul>
      {links.map(l => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
      <li class="mobile-lang">
        {Object.entries(languages).map(([code, label]) => (
          <a href={langHref(code)} class={lang === code ? 'active' : ''}>{label}</a>
        ))}
      </li>
      <li><a href={AIRBNB_URL} target="_blank" rel="noopener" class="btn btn--primary" style="margin-top:1rem;display:inline-flex">{t('nav.book')}</a></li>
      <li><a href={MUSIC_HUB_URL} target="_blank" rel="noopener" class="btn btn--ghost" style="margin-top:0.6rem;display:inline-flex;gap:0.5rem">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18V5l12-2v13"/>
          <circle cx="6" cy="18" r="3"/>
          <circle cx="18" cy="16" r="3"/>
        </svg>
        {t('nav.music')}
      </a></li>
    </ul>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    padding: 1.2rem var(--gutter);
    transition: all var(--dur) var(--ease);
    background: rgba(11, 9, 7, 0.5);
    backdrop-filter: blur(12px) saturate(130%);
    border-bottom: 1px solid rgba(244, 237, 227, 0.05);
  }
  nav.scrolled {
    padding-block: 0.8rem;
    backdrop-filter: blur(20px) saturate(155%);
    background: rgba(11, 9, 7, 0.8);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--fg);
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.01em;
    font-size: 1.1rem;
    line-height: 1;
  }
  .brand-mark {
    width: 70px; height: 70px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--ember-400);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    transition: all var(--dur) var(--ease);
  }
  .brand-mark svg { width: 36px; height: 36px; }
  .brand:hover .brand-mark {
    background: var(--ember-500);
    color: var(--ink-950);
    border-color: var(--ember-500);
    transform: rotate(-6deg);
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1; }
  .brand-chez {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    color: var(--fg-dim);
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 2.2rem;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    gap: 2.4rem;
    list-style: none;
  }
  .nav-links a {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.08rem;
    letter-spacing: -0.005em;
    color: var(--fg-muted);
    position: relative;
    transition: color var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
  }
  .nav-links a:hover {
    color: var(--ember-200);
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -8px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ember-400) 25%, var(--ember-300) 50%, var(--ember-400) 75%, transparent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--dur) var(--ease);
  }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .lang-switch {
    display: flex;
    gap: 0.2rem;
    align-items: center;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
  }
  .lang-switch .lang {
    padding: 0.35rem 0.55rem;
    color: var(--fg-dim);
    border-radius: 4px;
    font-weight: 500;
    transition: color var(--dur-fast) var(--ease);
  }
  .lang-switch .lang:hover { color: var(--ember-300); }
  .lang-switch .lang.active {
    color: var(--ember-400);
  }

  .btn--sm { padding: 0.6rem 1.1rem; font-size: 0.85rem; }

  /* Stack vertical Réserver + Music Hub, top-right de la nav */
  .cta-stack {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.5rem;
  }
  .cta-stack .btn {
    min-width: 130px;
    justify-content: center;
  }
  .cta-music {
    /* Variante discrète, taille identique au "Réserver" */
    background: rgba(11, 9, 7, 0.45);
    backdrop-filter: blur(10px);
    border-color: rgba(237, 170, 106, 0.28);
    color: var(--ember-200);
  }
  .cta-music:hover:not(:disabled) {
    color: var(--ember-100);
    border-color: rgba(237, 170, 106, 0.55);
    background: rgba(58, 26, 10, 0.55);
  }
  .cta-music svg { flex-shrink: 0; opacity: 0.9; }

  .burger {
    display: none;
    width: 40px; height: 40px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    cursor: pointer;
    padding: 10px;
  }
  .burger span {
    display: block;
    height: 1.5px;
    background: var(--fg);
    transition: all var(--dur) var(--ease);
  }
  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    inset: 0;
    background: rgba(11, 9, 7, 0.97);
    backdrop-filter: blur(24px);
    padding: 6rem 2rem 3rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur) var(--ease);
    z-index: -1;
  }
  .mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }
  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 440px;
    margin: 0 auto;
  }
  .mobile-menu a {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: var(--fg);
    letter-spacing: -0.02em;
  }
  .mobile-lang {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .mobile-lang a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--fg-dim);
  }
  .mobile-lang a.active { color: var(--ember-400); }

  @media (max-width: 940px) {
    .nav-links { display: none; }
    .lang-switch { display: none; }
    .burger { display: inline-flex; }
    .cta-stack { display: none; }
  }
</style>
