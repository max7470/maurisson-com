---
import { useTranslations, type Lang } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const tiles = [
  { k: 'house.tile.1', src: '/photos/04-salon-cheminee.avif' },
  { k: 'house.tile.2', src: '/photos/05-piano.avif' },
  { k: 'house.tile.3', src: '/photos/07-cuisine-detail.avif' },
  { k: 'house.tile.4', src: '/photos/09-terrasse.avif' },
  { k: 'house.tile.5', src: '/photos/11-jardin-hamac.avif' },
  { k: 'house.tile.6', src: '/photos/03-salle-de-bain.avif' },
];
---
<section id="house" class="house">
  <div class="container">
    <div class="house-intro">
      <p class="eyebrow reveal">{t('house.eyebrow')}</p>
      <h2 class="house-title display reveal delay-1">{t('house.title')}</h2>
      <p class="house-body body-lg reveal delay-2">{t('house.body')}</p>
    </div>

    <div class="house-grid">
      {tiles.map((tile, i) => (
        <figure class={'tile reveal delay-' + ((i % 3) + 1)} style={'--i:' + i}>
          <img src={tile.src} alt="" loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .house { background: linear-gradient(180deg, transparent 0%, rgba(18, 15, 12, 0.6) 40%, transparent 100%); }
  .house-intro {
    max-width: 58ch;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .house-title {
    font-size: clamp(2.4rem, 1.6rem + 4vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-block: 1.2rem 2rem;
  }
  .house-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1rem;
  }
  .tile {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    cursor: pointer;
    background: var(--ink-800);
    transition: transform var(--dur) var(--ease);
  }
  .tile:hover { transform: translateY(-4px); }
  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease), filter var(--dur) var(--ease);
    filter: brightness(0.85) saturate(0.95);
  }
  .tile:hover img {
    transform: scale(1.06);
    filter: brightness(1) saturate(1.05);
  }
  .tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(11,9,7,0.92) 100%);
    pointer-events: none;
  }
  figcaption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.4rem 1.4rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    z-index: 1;
  }
  .tile-num {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--ember-300);
    opacity: 0.8;
  }
  .tile-label {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 0.9rem + 0.3vw, 1.25rem);
    letter-spacing: -0.01em;
    color: var(--ink-50);
  }

  /* bento layout */
  .tile:nth-child(1) { grid-column: span 7; aspect-ratio: 16/10; }
  .tile:nth-child(2) { grid-column: span 5; aspect-ratio: 4/5; grid-row: span 2; }
  .tile:nth-child(3) { grid-column: span 4; aspect-ratio: 1/1; }
  .tile:nth-child(4) { grid-column: span 3; aspect-ratio: 1/1; }
  .tile:nth-child(5) { grid-column: span 7; aspect-ratio: 16/10; }
  .tile:nth-child(6) { grid-column: span 5; aspect-ratio: 4/3; }

  @media (max-width: 900px) {
    .tile:nth-child(n) {
      grid-column: span 12;
      aspect-ratio: 4/3;
      grid-row: auto;
    }
  }
</style>
