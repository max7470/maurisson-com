---
import { useTranslations, type Lang } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---
<section class="intro">
  <div class="container container--narrow">
    <h2 class="intro-title display reveal">{t('intro.title')}</h2>
    <p class="intro-body reveal delay-1">{t('intro.body')}</p>
  </div>
  <div class="marker" aria-hidden="true">
    <svg viewBox="0 0 40 60" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
      <circle cx="20" cy="20" r="8"/>
      <path d="M20 28 L20 55"/>
      <circle cx="20" cy="20" r="3" fill="currentColor"/>
    </svg>
  </div>
</section>

<style>
  .intro {
    padding-block: clamp(7rem, 14vw, 14rem);
    text-align: center;
    position: relative;
  }
  .intro-title {
    font-size: clamp(2.2rem, 1.8rem + 3vw, 4.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 2.5rem;
    color: var(--ink-50);
  }
  .intro-body {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.1rem, 0.95rem + 0.6vw, 1.45rem);
    line-height: 1.55;
    color: var(--ink-200);
    max-width: 52ch;
    margin: 0 auto;
    letter-spacing: -0.01em;
  }
  .marker {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--ember-500);
    opacity: 0.5;
  }
  .marker svg { width: 18px; height: 28px; }
</style>
