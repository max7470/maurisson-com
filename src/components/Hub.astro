---
import {
  useTranslations,
  type Lang,
  languages,
  AIRBNB_URL,
  MUSIC_HUB_URL,
  GREEN_HUB_URL,
  SITES_URL,
  MANUELS_URL,
  MUSIC_COUNT,
  GREEN_COUNT,
  roomUrl,
  hubUrl,
} from '../i18n/ui';
import { legal } from '../i18n/legal';
import { stats } from '../data/reviews';

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const room = roomUrl(lang);
const langHref = (l: string) => hubUrl(l as Lang);
const formatCount = (n: number) => n.toLocaleString(lang === 'en' ? 'en-US' : 'fr-FR');
const legalPath = lang === 'fr' ? '/legal' : `/${lang}/legal`;

const musicBody = t('hub.music.body').replace('{count}', formatCount(MUSIC_COUNT));
const greenBody = t('hub.green.body').replace('{count}', String(GREEN_COUNT));

const musicFeatures = [1, 2, 3, 4, 5, 6] as const;
const greenFeatures = [1, 2, 3] as const;
---

<section class="hub">
  <div class="noise" aria-hidden="true"></div>

  <header class="hub-top container">
    <a href={hubUrl(lang)} class="hub-brand" aria-label="Mauriss">
      <svg class="hub-brand-logo" viewBox="13.94 45.37 808.31 500.15" xmlns="http://www.w3.org/2000/svg" shape-rendering="geometricPrecision" role="img" aria-label="Mauriss">
        <path transform="matrix(1,0,0,-1,477.2441,360.49653)" d="M0 0C-8.093 13.948-12.555 21.894-13.622 24.253-24.995 50.78-31.883 79.404-34.096 109.327-36.514 142.039-36.714 209.59-34.689 310.104L-38.536 310.74C-61.667 237.825-78.881 182.798-91.16 142.524-108.048 87.926-119.349 54.058-124.726 41.907-127.693 35.669-129.407 35.02-129.72 34.953-129.798 34.938-129.923 34.911-130.142 35.096-135.085 39.797-143.812 62.548-157.315 144.24-168.86 214.439-177.476 267.899-182.923 303.134L-183.649 307.834-186.459 303.998C-189.656 299.63-194.034 293.246-199.487 284.993-205.226 275.986-210.064 268.54-213.995 262.657L-186.964 274.699-180.981 221.411C-171.995 169.985-165.162 128.21-160.615 96.854-145.808 7.781-135.932-6.908-129.763-10.225-128.121-11.072-126.303-11.096-124.507-10.291-118.212-7.468-107.209 6.562-84.435 95.463-66.712 169.597-52.937 228.442-43.394 270.776-42.922 235.865-42.774 194.021-42.959 146.079-43.114 97.311-43.108 72.495-42.939 70.209-42.658 66.425-38.87 44.451-31.36 3.044-22.514-47.242-16.308-83.147-12.387-106.723L-8.479-106.547C-4.85-58.261-1.912-22.812 .255-1.186L.319-.552Z" fill="currentColor"/>
