<style>
  .hub {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    padding-block: 0 clamp(2.5rem, 5vh, 4rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3.5rem);
    isolation: isolate;
    overflow: hidden;
  }
  .hub .noise {
    z-index: -2;
  }

  /* ──────────────────────────────────────────────────────────────
     AMBIANCE LUMIÈRE — chaleur vivante, CSS only
     ────────────────────────────────────────────────────────────── */

  /* Aurora : 3 sources de chaleur. Blur STATIQUE (pas dans l'anim) → GPU only.
     N'anime que transform + opacity, qui sont compositor-only et n'invalident pas le paint. */
  .hub::before {
    content: '';
    position: absolute;
    inset: -8% -6% 20% -6%;
    z-index: -3;
    pointer-events: none;
    background:
      radial-gradient(52% 42% at 18% 16%, var(--ember-glow-soft), transparent 65%),
      radial-gradient(46% 38% at 82% 28%, rgba(154, 200, 138, 0.09), transparent 72%),
      radial-gradient(58% 42% at 50% 78%, var(--ember-glow-dim), transparent 75%);
    /* blur appliqué une seule fois, JAMAIS animé → reste léger */
    filter: blur(24px) saturate(120%);
    transform: translate3d(0, 0, 0);
    will-change: transform, opacity;
    animation: hub-aurora 22s ease-in-out infinite alternate;
  }
  /* Light beam : cône chaud, sans mix-blend-mode (composite expensive).
     Le screen blend ne valait pas son coût en perf. */
  .hub::after {
    content: '';
    position: absolute;
    top: -8%;
    left: 50%;
    width: min(1100px, 85vw);
    height: clamp(420px, 60vh, 720px);
    z-index: -2;
    pointer-events: none;
    background: radial-gradient(
      ellipse 56% 92% at 50% 0%,
      rgba(237, 170, 106, 0.20) 0%,
      rgba(224, 138, 68, 0.08) 30%,
      rgba(224, 138, 68, 0.02) 55%,
      transparent 75%
    );
    transform: translate3d(-50%, 0, 0);
    will-change: transform, opacity;
    animation: hub-beam 12s ease-in-out infinite;
  }
  @keyframes hub-aurora {
    0%   { opacity: 0.7;  transform: translate3d(0, 0, 0) scale(1); }
    100% { opacity: 1;    transform: translate3d(-2%, 1%, 0) scale(1.04); }
  }
  @keyframes hub-beam {
    0%, 100% { opacity: 0.7; transform: translate3d(-50%, 0, 0) scaleX(1); }
    50%      { opacity: 1;   transform: translate3d(-50%, 0, 0) scaleX(1.06); }
  }

  /* TOP STRIP */
  .hub-top {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.5rem;
    padding-block: clamp(1.2rem, 2vh, 1.8rem);
    position: relative;
  }
  .hub-top::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: clamp(60px, 8vw, 110px);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ember-400) 50%, transparent);
    opacity: 0.6;
  }
  .hub-brand {
    position: absolute;
    top: clamp(0.8rem, 1.6vh, 1.5rem);
    left: var(--gutter);
    display: inline-flex;
    align-items: flex-start;
    color: var(--fg);
    line-height: 1;
    z-index: 2;
  }
  .hub-brand-logo {
    display: block;
    height: clamp(51px, 7.7vw, 119px);
    width: auto;
    color: var(--ember-400);
    transition:
      color var(--dur-fast) var(--ease),
      transform var(--dur) var(--ease),
      filter var(--dur) var(--ease);
    filter: drop-shadow(0 1px 4px rgba(224, 138, 68, 0.18));
  }
  .hub-brand:hover .hub-brand-logo {
    color: var(--ember-300);
    transform: rotate(-3deg) scale(1.04);
    filter: drop-shadow(0 2px 8px rgba(224, 138, 68, 0.32));
  }
  .hub-top-langs {
    display: inline-flex;
    gap: 0.2rem;
    padding: 0.3rem;
    background: rgba(244, 237, 227, 0.03);
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .top-lang {
    padding: 0.35rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--fg-dim);
    border-radius: 999px;
    transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .top-lang:hover {
    color: var(--ember-200);
    background: rgba(244, 237, 227, 0.05);
  }
  .top-lang.active {
    color: var(--ink-950);
    background: var(--ember-400);
  }

  /* HEADER */
  .hub-header {
    text-align: center;
  }
  .hub-header-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(2.5rem, 7vw, 6rem);
    margin-bottom: clamp(1.2rem, 2.5vw, 2rem);
  }
  .hub-title {
    font-size: clamp(2.2rem, 1.5rem + 4.2vw, 5.4rem);
    line-height: 0.98;
    margin: 0;
    color: var(--ink-50);
    font-weight: 300;
    letter-spacing: -0.02em;
    text-align: right;
  }
  .hub-title .t-line {
    display: block;
    white-space: nowrap;
  }
  .hub-title .t-em {
    font-style: italic;
    font-weight: 300;
    background: linear-gradient(95deg,
      var(--ember-300) 0%,
      var(--ember-100) 25%,
      var(--ember-200) 50%,
      var(--ember-300) 75%,
      var(--ember-400) 100%);
    background-size: 220% 100%;
    background-position: 0% 0%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 0 16px var(--ember-glow-dim));
    animation: t-em-shimmer 14s ease-in-out infinite;
    will-change: background-position, filter;
  }
  @keyframes t-em-shimmer {
    0%, 100% {
      background-position: 0% 0%;
      filter: drop-shadow(0 0 12px var(--ember-glow-dim));
    }
    50% {
      background-position: 100% 0%;
      filter: drop-shadow(0 0 28px var(--ember-glow-soft));
    }
  }
  .hub-categories {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: clamp(0.2rem, 0.4vw, 0.4rem);
    border-left: 1px solid var(--border-strong);
    padding-left: clamp(1.4rem, 3vw, 2.2rem);
  }
  .hub-categories li {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1rem, 0.75rem + 1.4vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--ink-100);
  }
  .hub-categories li:nth-child(2) {
    color: var(--ember-200);
  }
  .hub-motto {
    display: inline-block;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.85rem + 0.55vw, 1.4rem);
    line-height: 1.35;
    color: var(--ink-100);
    letter-spacing: -0.005em;
    text-align: center;
    position: relative;
    padding-inline: clamp(0.5rem, 2vw, 1.5rem);
    max-width: min(540px, calc(100% - 3rem));
  }
  .hub-motto em {
    font-style: italic;
    font-weight: 300;
  }
  .hub-motto::before,
  .hub-motto::after {
    content: '';
    position: absolute;
    top: 50%;
    width: clamp(28px, 5vw, 56px);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ember-300));
    opacity: 0.6;
  }
  .hub-motto::before {
    right: calc(100% + 0.4rem);
    background: linear-gradient(90deg, transparent, var(--ember-300));
  }
  .hub-motto::after {
    left: calc(100% + 0.4rem);
    background: linear-gradient(90deg, var(--ember-300), transparent);
  }

  /* BENTO STACK */
  .hub-bento {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.6vw, 1.4rem);
  }

  /* ──────────────────────────────────────────────────────────────
     BENTO WIDE — Music & Green : full-width, text à gauche + features à droite
     ────────────────────────────────────────────────────────────── */
  .bento-wide {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: center;
    padding: clamp(1.6rem, 2.5vw, 2.4rem);
    border-radius: 22px;
    /* Spotlight cursor + base gradient. contain:paint isole les repaints
       à la card seule (pas tout le hub) → spotlight fluide. */
    background:
      radial-gradient(280px circle at var(--mx, 50%) var(--my, 50%), rgba(253, 228, 192, 0.10), transparent 55%),
      linear-gradient(180deg, var(--ink-800) 0%, var(--ink-900) 100%);
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-md);
    color: var(--fg);
    text-decoration: none;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    contain: paint;
    transition: transform var(--dur) var(--ease), border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .bento-wide::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(75% 55% at 0% 0%, var(--wide-accent), transparent 60%);
    opacity: 0.7;
    pointer-events: none;
    z-index: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .bento-wide:hover {
    transform: translateY(-3px);
    border-color: var(--wide-border-hover);
    box-shadow:
      0 24px 50px -16px rgba(0,0,0,0.55),
      0 0 0 3px var(--wide-glow);
  }
  .bento-wide:hover::before { opacity: 1; }

  .bento-wide.music {
    --wide-accent: var(--ember-glow-dim);
    --wide-border-hover: rgba(237, 170, 106, 0.55);
    --wide-glow: var(--ember-glow-soft);
    --wide-fg: var(--ember-200);
    --wide-fg-strong: var(--ember-300);
    --wide-bg: rgba(224, 138, 68, 0.14);
  }
  .bento-wide.green {
    --wide-accent: rgba(154, 200, 138, 0.20);
    --wide-border-hover: rgba(154, 200, 138, 0.55);
    --wide-glow: rgba(154, 200, 138, 0.22);
    --wide-fg: #c7e3ba;
    --wide-fg-strong: #b8da9b;
    --wide-bg: rgba(90, 115, 96, 0.22);
  }

  .wide-text {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-width: 0;
  }
  .wide-head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.3rem;
  }
  .wide-icon {
    width: 44px; height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--wide-fg);
    background: var(--wide-bg);
    border-radius: 12px;
    flex-shrink: 0;
