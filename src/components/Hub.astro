  .wide-icon svg { width: 22px; height: 22px; }
  .wide-eyebrow-count {
    color: var(--fg);
    letter-spacing: 0.14em;
  }
  .wide-title {
    font-size: clamp(1.8rem, 1.4rem + 1.8vw, 2.8rem);
    line-height: 1;
    margin: 0;
    color: var(--ink-50);
    font-weight: 300;
    letter-spacing: -0.02em;
  }
  .wide-body {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(0.98rem, 0.9rem + 0.3vw, 1.15rem);
    line-height: 1.5;
    color: var(--ink-100);
    margin: 0;
    max-width: 60ch;
    letter-spacing: -0.005em;
  }
  .wide-cta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.4rem;
    padding: 0.7rem 1.2rem;
    background: rgba(244, 237, 227, 0.06);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.86rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--wide-fg);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .bento-wide:hover .wide-cta {
    background: var(--wide-bg);
