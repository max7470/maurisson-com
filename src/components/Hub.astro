  }
  .wide-cta .arrow {
    transition: transform var(--dur) var(--ease);
  }
  .bento-wide:hover .wide-cta .arrow {
    transform: translateX(3px);
  }

  /* FEATURE PILLS GRID */
  .wide-features {
    position: relative;
    z-index: 1;
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
    min-width: 0;
  }
  .wide-features-music {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
