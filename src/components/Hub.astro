    line-height: 1.3;
  }

  /* AIRBNB BLOCK (inchangé) */
  .bento-airbnb {
    display: flex;
    flex-direction: column;
    border-radius: 22px;
    overflow: hidden;
    isolation: isolate;
    contain: paint;
    background:
      radial-gradient(280px circle at var(--mx, 50%) var(--my, 50%), rgba(253, 228, 192, 0.10), transparent 55%),
      linear-gradient(180deg, var(--ink-800) 0%, var(--ink-900) 100%);
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-md);
    color: var(--fg);
    text-decoration: none;
