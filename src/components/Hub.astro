        <path transform="matrix(1,0,0,-1,593.4736,204.5444)" d="M0 0-.365-.177-.763-31.655 2.963-27.196C6.883-21.96 11.77-18.119 17.499-15.768L20.074-103.756C13.397-123.321 4.27-138.04-7.059-147.507L-7.488-147.866-7.203-148.346C6.313-171.119 14.483-195.806 17.246-221.967 1.992-217.963-10.685-199.137-20.445-165.992-28.471-132.092-33.563-107.238-35.597-92.033-43.601-47.536-45.33-38.551-45.906-36.451L-45.876-36.445C-50.368-16.14-56.814 3.131-65.045 20.865-58.884 24.897-52.293 30.542-45.433 37.669-40.333 42.959-36.08 46.939-32.757 49.547L-27.139 52.875C-26.301 53.383-25.48 53.882-24.674 54.375-8.313 62.851 4.468 69.324 14.377 74.155 15.245 74.646 16.08 75.131 16.905 75.616 17.229 69.158 20.25 63.324 25.944 58.297L27.887 56.308 43.298 101.656 41.862 100.929C41.5 100.746 41.165 100.565 40.812 100.382L40.949 101.209 8.812 108.481 8.557 108.472C-52.504 106.325-102.306 101.623-139.467 94.495L-140.878 94.224-141.052 92.798C-141.284 90.891-141.509 89.017-141.729 87.164L-140.13 32.799C-132.009 61.451-119.196 80.565-101.931 89.698-91.732 95.137-73.533 98.841-47.805 100.708-28.191 102.454-14.622 102.898-7.479 102.028L-3.139 101.502C15.111 98.859 14.077 90.338 13.735 87.54 13.532 85.874 9.135 79.662-26.627 57.799-28.068 57.052-29.535 56.29-31.033 55.512-32.205 54.836-33.509 53.943-34.956 52.823L-60.559 37.658C-68.807 32.667-75.341 28.685-78.961 26.447L-80.595 25.437-79.626 23.778C-66.441 1.202-55.414-29.956-46.861-68.777-40.792-100.475-34.392-133.362-27.826-166.598-24.454-180.841-19.994-193.146-14.571-203.169L-14.412-203.417C-13.92-204.087-4.436-218.082 3.783-230.214 11.659-241.604 16.079-251.021 16.92-258.207 17.143-265.882 17.276-272.844 17.318-279.068 16.2-286.129 14.668-293.705 12.501-301.821L11.916-304.012 20.649-305.072 20.78-302.988C21.166-296.832 21.329-289.014 21.265-279.346 22.687-270.283 23.437-262.08 23.978-254.675 24.942-251.044 25.814-247.261 26.591-243.323L29.237-226.345C30.098-219.088 30.694-211.427 31.019-203.369 31.033-202.812 31.048-202.223 31.062-201.62 31.174-200.035 31.233-199.157 31.237-199.098L31.121-199.09C31.438-184.652 31.735-159.687 32.003-124.726 31.75-68.225 31.847-21.675 32.292 13.631L32.305 14.652 31.371 14.24C16.821 7.832 6.561 3.174 0 0" fill="currentColor"/>
        <path transform="matrix(1,0,0,-1,511.8574,120.23871)" d="M0 0C-3.781-11.541-7.226-29.938-10.238-54.682-13.125-78.402-15.28-96.378-16.643-108.109-17.333-114.057-17.835-118.521-18.147-121.501-18.367-123.59-18.515-125-18.507-125.965-19.788-131.224-23.179-138.624-28.586-147.971-37.259-162.956-37.43-164.368-37.521-165.125-37.86-167.902-37.051-171.147-35.051-175.048-33.374-178.317-32.324-180.678-31.924-182.07-30.592-197.646-30.046-211.446-30.301-223.09L-26.412-223.581C-21.807-203.848-20.519-198.872-20.249-198.172L-19.961-197.419-20.195-196.88C-20.216-196.34-20.108-194.239-18.736-186.23L-14.493-151.358-14.49-151.333C-9.903-108.789-3.74-58.167 3.825-.871Z" fill="currentColor"/>
        <path transform="matrix(1,0,0,-1,776.4482,416.6596)" d="M0 0C-1.957 .986-14.815 3.254-39.31 6.933-63.016 10.482-80.848 19.914-92.321 34.967-86.762 43.806-78.533 51.086-67.861 56.61-57.952 61.59-47.596 64.114-37.082 64.114-25.181 64.114-16.354 57.869-10.845 45.551L-10.08 43.841-9.61 45.655C-4.321 66.062-.045 82.185 3.1 93.578L3.598 95.382 2.081 94.285C-3.505 90.24-12.093 86.686-23.444 83.717-35.965 80.444-47.32 77.423-58.171 74.48-72.346 70.371-83.229 65.227-90.539 59.174-99.774 50.872-104.458 40.024-104.458 26.932-104.458 24.038-104.297 20.987-103.979 17.863L-103.95 17.568-103.709 17.396C-92.662 9.479-79.701 4.18-65.11 1.636-53.106 .973-41.115 .175-29.469-.738-17.551-1.673-9.027-4.633-4.138-9.537 2.269-15.967 5.228-27.807 4.659-44.729-11.161-55.227-27.355-60.548-43.478-60.548-52.233-60.548-63.014-58.96-75.519-55.83-90.193-52.099-102.068-47.035-110.814-40.781L-111.853-40.038V-133.06L-110.569-133.253C-107.604-123.616-105.795-117.555-104.889-114.219-100.224-100.729-95.172-91.031-89.854-85.368-83.087-77.311-73.381-73.226-61.005-73.226-56.361-73.226-51.313-73.694-45.996-74.622-42.496-75.578-38.78-76.063-34.951-76.063-21.575-76.063-8.678-70.104 3.392-58.344 14.037-47.698 19.211-39.34 19.211-32.788 19.211-16.165 12.731-5.125 0 0" fill="currentColor"/>
        <path transform="matrix(1,0,0,-1,806.9316,342.352)" d="M0 0C0 13.695-2.17 27.594-6.497 41.681-7.685 45.975-8.263 49.098-8.263 51.065-8.263 58.108-.408 65.745 15.318 73.96 14.538 70.821 9.431 46.162 0 0" fill="currentColor"/>
        <path transform="matrix(1,0,0,-1,361.7705,333.0541)" d="M0 0C1.907 0 2.202 2.972 .281 2.972-1.625 2.972-1.92 0 0 0" fill="currentColor"/>
        <path transform="matrix(1,0,0,-1,761.124,181.62439)" d="M0 0V30.101C0 30.101 4.014 55.519 16.054 80.938 16.054 80.938-28.764 53.512-82.944 28.763-82.944 28.763-113.366 16.057-113.715-27.425-114.049-69.232-74.583-57.192-74.583-57.192-74.583-57.192-23.139-43.915-18.135-74.249-12.784-106.691-23.486-120.403-40.209-129.769-56.932-139.133-83.316-157.862-123.451-129.769V-246.158H-117.394C-117.394-246.158-120.738-159.869-67.895-150.839-21.983-142.993-5.76-129.1 .26-95.988 6.28-62.877-12.784-40.804-35.192-40.804-51.611-40.804-80.938-41.807-80.938-41.807-80.938-41.807-100.336-41.473-95.319-7.693-90.303 26.087-39.466 38.462-17.058 44.816-17.058 44.816-8.696 46.489-8.696 32.107V-.334Z" fill="currentColor"/>
      </svg>
    </a>

    <div class="hub-top-langs" aria-label="Language">
      {Object.entries(languages).map(([code, label]) => (
        <a
          href={langHref(code)}
          class={'top-lang' + (lang === code ? ' active' : '')}
          aria-current={lang === code ? 'page' : undefined}
        >{label}</a>
      ))}
    </div>
  </header>

  <div class="hub-header container reveal">
    <div class="hub-header-row">
      <h1 class="hub-title display">
        <span class="t-line">{t('hub.title.l1')} <em class="t-em">{t('hub.title.em')}</em></span>
        <span class="t-line">{t('hub.title.l3')}</span>
      </h1>
      <ul class="hub-categories" aria-label="Catégories">
        <li>{t('hub.cat.1')}</li>
        <li>{t('hub.cat.2')}</li>
        <li>{t('hub.cat.3')}</li>
      </ul>
    </div>
    <p class="hub-motto"><em>{t('hub.motto')}</em></p>
  </div>

  <div class="hub-bento container">
    <!-- MUSIC HUB — full width, premier de la liste, mis en avant -->
    <a href={MUSIC_HUB_URL} target="_blank" rel="noopener noreferrer" class="bento-wide music reveal delay-1">
      <div class="wide-text">
        <div class="wide-head">
          <span class="wide-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18V5l12-2v13"/>
              <circle cx="6" cy="18" r="3"/>
              <circle cx="18" cy="16" r="3"/>
            </svg>
          </span>
          <span class="bento-eyebrow">
            {t('hub.music.eyebrow')} · <span class="wide-eyebrow-count">{formatCount(MUSIC_COUNT)} {t('hub.music.stat')}</span>
          </span>
        </div>
        <h2 class="wide-title display">{t('hub.music.title')}</h2>
        <p class="wide-body">{musicBody}</p>
        <span class="wide-cta">
          {t('hub.visit')}
          <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </span>
      </div>

      <ul class="wide-features wide-features-music" aria-label="Features">
        {musicFeatures.map((i) => (
          <li class="feat-pill">
            <span class="feat-icon" aria-hidden="true">
              {i === 1 && (
                /* piano keys */
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="6" width="18" height="12" rx="1.5"/>
                  <path d="M9 6v8M15 6v8"/>
                  <rect x="6.5" y="6" width="2.2" height="6" fill="currentColor" stroke="none"/>
                  <rect x="11.4" y="6" width="2.2" height="6" fill="currentColor" stroke="none"/>
                  <rect x="16" y="6" width="2.2" height="6" fill="currentColor" stroke="none"/>
                </svg>
              )}
              {i === 2 && (
                /* ChordPro chord-over-lyric */
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 7h2M11 7h3M17 7h2"/>
                  <path d="M4 13h16"/>
                  <path d="M4 17h11"/>
                </svg>
              )}
              {i === 3 && (
                /* MIDI / sheet music */
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 7h18M3 11h18M3 15h18"/>
                  <circle cx="8" cy="13" r="1.5" fill="currentColor" stroke="none"/>
                  <path d="M9.5 13V6.5"/>
                  <circle cx="16" cy="11" r="1.5" fill="currentColor" stroke="none"/>
                  <path d="M17.5 11V4.5"/>
                </svg>
              )}
              {i === 4 && (
                /* Harmonica holes */
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="8" width="18" height="8" rx="1.5"/>
                  <circle cx="7" cy="12" r="1.1" fill="currentColor" stroke="none"/>
                  <circle cx="10.5" cy="12" r="1.1" fill="currentColor" stroke="none"/>
                  <circle cx="14" cy="12" r="1.1" fill="currentColor" stroke="none"/>
                  <circle cx="17.5" cy="12" r="1.1" fill="currentColor" stroke="none"/>
                </svg>
              )}
              {i === 5 && (
                /* Sync arrows */
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 12a8 8 0 0 1 14-5"/>
                  <path d="M18 3v4h-4"/>
                  <path d="M20 12a8 8 0 0 1-14 5"/>
                  <path d="M6 21v-4h4"/>
                </svg>
              )}
              {i === 6 && (
                /* Phone offline */
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="6" y="2.5" width="12" height="19" rx="2.5"/>
                  <path d="M10 18.5h4"/>
                  <path d="M9 10l6 4M15 10l-6 4"/>
                </svg>
              )}
            </span>
            <span class="feat-text">
              <span class="feat-title">{t(`hub.music.feat.${i}.title` as any)}</span>
              <span class="feat-sub">{t(`hub.music.feat.${i}.sub` as any)}</span>
            </span>
          </li>
        ))}
      </ul>
    </a>

    <!-- AIRBNB BLOCK -->
    <a href={room} class="bento-airbnb reveal delay-2">
      <div class="airbnb-text">
        <div class="airbnb-text-head">
          <div class="airbnb-place">
            <span class="bento-eyebrow">{t('hub.airbnb.eyebrow')}</span>
            <span class="airbnb-coords">{t('hub.airbnb.coords')}</span>
          </div>
          <span class="bento-airbnb-badge">
            <svg class="laurel" viewBox="0 0 32 96" aria-hidden="true">
              <g fill="currentColor">
                <ellipse cx="20" cy="86" rx="6" ry="2.2" transform="rotate(-25 20 86)"/>
                <ellipse cx="14" cy="72" rx="6.5" ry="2.4" transform="rotate(-40 14 72)"/>
                <ellipse cx="10" cy="56" rx="7" ry="2.6" transform="rotate(-55 10 56)"/>
                <ellipse cx="9" cy="40" rx="7" ry="2.6" transform="rotate(-72 9 40)"/>
                <ellipse cx="13" cy="24" rx="6" ry="2.4" transform="rotate(-90 13 24)"/>
                <ellipse cx="21" cy="12" rx="5" ry="2.2" transform="rotate(-108 21 12)"/>
              </g>
            </svg>
            <span class="bb-core">
              <span class="bb-rating">
                <svg class="bb-star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.9 7.4.6-5.6 4.9 1.7 7.3L12 17.8 5.6 21.7l1.7-7.3-5.6-4.9 7.4-.6z"/></svg>
                <span class="bb-value">{stats.rating}</span>
              </span>
              <span class="bb-label">{t('hero.badge')}</span>
              <span class="bb-count">{stats.count} {t('hero.reviewsWord')}</span>
            </span>
            <svg class="laurel laurel--r" viewBox="0 0 32 96" aria-hidden="true">
              <g fill="currentColor">
                <ellipse cx="12" cy="86" rx="6" ry="2.2" transform="rotate(25 12 86)"/>
                <ellipse cx="18" cy="72" rx="6.5" ry="2.4" transform="rotate(40 18 72)"/>
                <ellipse cx="22" cy="56" rx="7" ry="2.6" transform="rotate(55 22 56)"/>
                <ellipse cx="23" cy="40" rx="7" ry="2.6" transform="rotate(72 23 40)"/>
                <ellipse cx="19" cy="24" rx="6" ry="2.4" transform="rotate(90 19 24)"/>
                <ellipse cx="11" cy="12" rx="5" ry="2.2" transform="rotate(108 11 12)"/>
              </g>
            </svg>
          </span>
        </div>
        <h2 class="bento-airbnb-title display">{t('hub.airbnb.title')}</h2>
        <p>{t('hub.airbnb.body')}</p>
        <span class="bento-airbnb-cta">
          {t('hub.airbnb.cta')}
          <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </span>
      </div>
      <div class="airbnb-media">
        <img src="/photos/01-hero-salon.avif" alt="" loading="eager" fetchpriority="high" />
      </div>
    </a>

    <!-- GREEN HUB — full width sous Airbnb -->
    <a href={GREEN_HUB_URL} class="bento-wide green reveal delay-2">
