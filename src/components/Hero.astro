---
import { useTranslations, type Lang, AIRBNB_URL, AIRBNB_REVIEWS_URL } from '../i18n/ui';
import { stats } from '../data/reviews';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---
<section class="hero">
  <div class="hero-media">
    <img src="/photos/01-hero-salon.avif" alt="" fetchpriority="high" />
    <div class="hero-overlay"></div>
    <div class="noise"></div>
  </div>

  <div class="hero-content container">
    <div class="hero-eyebrow reveal">
      <span class="dot"></span>
      <span>{t('hero.eyebrow')}</span>
    </div>

    <h1 class="hero-title display">
      <span class="hero-line reveal">{t('hero.title.l1')}</span>
      <span class="hero-line hero-line--em reveal delay-1">
        <em>{t('hero.title.l2')}</em>
      </span>
      <span class="hero-line reveal delay-2">{t('hero.title.l3')}</span>
    </h1>

    <div class="hero-sub-row reveal delay-3">
      <p class="hero-sub">{t('hero.sub')}</p>
      <a href={AIRBNB_URL} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg hero-sub-cta">
        {t('hero.cta.primary')}
        <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>

  <a href={AIRBNB_REVIEWS_URL} target="_blank" rel="noopener noreferrer" class="hero-badge reveal delay-3" aria-label={stats.rating + ' / 5 — ' + t('hero.badge')}>
    <svg class="laurel laurel--l" viewBox="0 0 32 96" aria-hidden="true">
      <g fill="currentColor">
        <ellipse cx="20" cy="86" rx="6" ry="2.2" transform="rotate(-25 20 86)"/>
        <ellipse cx="14" cy="72" rx="6.5" ry="2.4" transform="rotate(-40 14 72)"/>
        <ellipse cx="10" cy="56" rx="7" ry="2.6" transform="rotate(-55 10 56)"/>
        <ellipse cx="9" cy="40" rx="7" ry="2.6" transform="rotate(-72 9 40)"/>
        <ellipse cx="13" cy="24" rx="6" ry="2.4" transform="rotate(-90 13 24)"/>
        <ellipse cx="21" cy="12" rx="5" ry="2.2" transform="rotate(-108 21 12)"/>
      </g>
    </svg>

    <div class="badge-core">
      <div class="badge-rating">
        <svg class="badge-star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.9 7.4.6-5.6 4.9 1.7 7.3L12 17.8 5.6 21.7l1.7-7.3-5.6-4.9 7.4-.6z"/></svg>
        <span class="badge-value">{stats.rating}</span>
      </div>
      <span class="badge-label">{t('hero.badge')}</span>
      <span class="badge-count">{stats.count} {t('hero.reviewsWord')}</span>
    </div>

    <svg class="laurel laurel--r" viewBox="0 0 32 96" aria-hidden="true">
      <g fill="currentColor">
        <ellipse cx="12" cy="86" rx="6" ry="2.2" transform="rotate(25 12 86)"/>
        <ellipse cx="18" cy="72" rx="6.5" ry="2.4" transform="rotate(40 18 72)"/>
        <ellipse cx="22" cy="56" rx="7" ry="2.6" transform="rotate(55 22 56)"/>
        <ellipse cx="23" cy="40" rx="7" ry="2.6" transform="rotate(72 23 40)"/>
        <ellipse cx="19" cy="24" rx="6" ry="2.4" transform="rotate(90 19 24)"/>
        <ellipse cx="11" cy="12" rx="5" ry="2.2" transform="rotate(108 11 12)"/>
      </g>
    </svg>
  </a>

  <div class="scroll-cue" aria-hidden="true">
    <span class="line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-block: 8rem 6rem;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    filter: brightness(0.75) contrast(1.05) saturate(1.05);
    will-change: transform;
    animation: slow-zoom 18s ease-in-out infinite alternate;
  }
  @keyframes slow-zoom {
    from { transform: scale(1.00); }
    to   { transform: scale(1.06); }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(80% 60% at 30% 40%, transparent, rgba(11,9,7,0.5) 70%, rgba(11,9,7,0.9) 100%),
      linear-gradient(180deg, rgba(11,9,7,0.55) 0%, rgba(11,9,7,0.2) 30%, rgba(11,9,7,0.85) 100%);
  }

  .hero-content {
    position: relative;
    max-width: var(--container);
    width: 100%;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ember-300);
    margin-bottom: 2.5rem;
  }
  .hero-eyebrow .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ember-400);
    box-shadow: 0 0 0 6px rgba(224, 138, 68, 0.15);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(224, 138, 68, 0.12); }
    50%     { box-shadow: 0 0 0 10px rgba(224, 138, 68, 0.04); }
  }

  .hero-title {
    font-size: clamp(3.8rem, 3rem + 6vw, 9rem);
    line-height: 0.92;
    font-weight: 300;
    letter-spacing: -0.035em;
    color: var(--ink-50);
    margin-bottom: 2.5rem;
  }
  .hero-line {
    display: block;
  }
  .hero-line--em em {
    font-style: italic;
    font-weight: 300;
    background: linear-gradient(95deg, var(--ember-300) 0%, var(--ember-200) 50%, var(--ember-400) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-sub-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
  }
  .hero-sub {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.1rem, 0.9rem + 0.6vw, 1.4rem);
    line-height: 1.45;
    max-width: 48ch;
    color: var(--ink-100);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .hero-sub-cta {
    flex-shrink: 0;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-badge {
    position: absolute;
    right: var(--gutter);
    top: 7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: rgba(18, 15, 12, 0.72);
    backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    color: var(--ember-200);
    text-decoration: none;
    z-index: 5;
    transition: transform var(--dur) var(--ease), border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .hero-badge:hover {
    transform: translateY(-2px);
    border-color: rgba(237, 170, 106, 0.55);
    box-shadow: 0 14px 30px -12px rgba(0,0,0,0.55), 0 0 0 3px var(--ember-glow-soft);
  }
  .laurel {
    width: 22px;
    height: 64px;
    color: var(--ember-300);
    flex-shrink: 0;
    filter: drop-shadow(0 0 8px rgba(237, 170, 106, 0.15));
  }
  .badge-core {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    gap: 0.25rem;
    padding-inline: 0.3rem;
  }
  .badge-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--ink-50);
    line-height: 1;
  }
  .badge-star {
    width: 14px;
    height: 14px;
    color: var(--ember-400);
    flex-shrink: 0;
  }
  .badge-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--ink-50);
  }
  .badge-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ember-200);
    white-space: nowrap;
  }
  .badge-count {
    font-size: 0.62rem;
    color: var(--fg-dim);
    letter-spacing: 0.1em;
  }

  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }
  .scroll-cue .line {
    display: block;
    width: 1px;
    height: 64px;
    background: linear-gradient(to bottom, transparent, var(--ember-300), transparent);
    animation: cue 2.4s ease-in-out infinite;
  }
  @keyframes cue {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.3; }
    50%      { transform: scaleY(1);   opacity: 1; }
  }

  @media (max-width: 780px) {
    .hero-sub-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .hero-badge {
      top: 1.1rem;
      right: var(--gutter);
      left: auto;
      max-width: none;
      gap: 0.5rem;
      padding: 0.4rem 0.7rem 0.4rem 0.55rem;
      border-radius: 999px;
      background: rgba(18, 15, 12, 0.78);
    }
    .hero-badge .laurel { display: none; }
    .badge-core {
      flex-direction: row;
      align-items: center;
      gap: 0.55rem;
      padding-inline: 0;
    }
    .badge-rating {
      gap: 0.3rem;
    }
    .badge-value {
      font-size: 1rem;
    }
    .badge-star {
      width: 12px;
      height: 12px;
    }
    .badge-label {
      font-size: 0.58rem;
      letter-spacing: 0.14em;
    }
    .badge-count {
      display: none;
    }
    .scroll-cue { display: none; }
  }
</style>
