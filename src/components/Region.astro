---
import { useTranslations, type Lang } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const pins = [
  { k: 'region.pin.1', x: 72, y: 18 },   // Maastricht (north-east, NL)
  { k: 'region.pin.2', x: 88, y: 48 },   // Aachen (east, DE)
  { k: 'region.pin.3', x: 48, y: 82 },   // Spa-Francorchamps (south-east)
  { k: 'region.pin.4', x: 18, y: 55 },   // Liège (west)
];
---
<section id="region" class="region">
  <div class="container">
    <div class="region-grid">
      <div class="region-text">
        <p class="eyebrow reveal">{t('region.eyebrow')}</p>
        <h2 class="region-title display reveal delay-1">
          <span>{t('region.title')}</span>
        </h2>
        <p class="region-body body-lg reveal delay-2">{t('region.body')}</p>

        <ul class="pin-list reveal delay-3">
          {pins.map((p) => (
            <li>
              <span class="pin-dot"></span>
              <div>
                <strong>{t((p.k + '.title') as any)}</strong>
                <small>{t((p.k + '.sub') as any)}</small>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="region-map reveal delay-2" aria-hidden="true">
        <div class="map">
          <!-- Center marker = Maurisson -->
          <div class="center-pin">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="16" cy="16" r="6"/><circle cx="16" cy="16" r="11" stroke-dasharray="2 3"/><circle cx="16" cy="16" r="14" stroke-dasharray="1 5" opacity="0.5"/></svg>
            <span class="center-label">Herve</span>
          </div>

          <!-- Pins -->
          {pins.map((p, i) => (
            <div class="pin" style={'--x:' + p.x + '%;--y:' + p.y + '%;--d:' + (i * 0.15) + 's'}>
              <span class="pin-marker"></span>
              <span class="pin-name">{t((p.k + '.title') as any)}</span>
              <span class="pin-sub">{t((p.k + '.sub') as any)}</span>
            </div>
          ))}

          <!-- connecting lines -->
          <svg class="lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            {pins.map(p => (
              <line x1="50" y1="50" x2={p.x} y2={p.y} stroke="currentColor" stroke-width="0.15" stroke-dasharray="0.8 1.2" />
            ))}
          </svg>

          <div class="map-grid" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .region {
    background: linear-gradient(180deg, transparent 0%, rgba(18, 15, 12, 0.8) 50%, transparent 100%);
    position: relative;
  }
  .region-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
  }
  .region-title {
    font-size: clamp(2.4rem, 1.6rem + 4vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-block: 1.2rem 2rem;
  }
  .region-title span {
    background: linear-gradient(95deg, var(--ink-50) 0%, var(--ember-200) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .region-body {
    margin-bottom: 2.5rem;
  }
  .pin-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .pin-list li {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .pin-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--ember-400);
    box-shadow: 0 0 0 4px rgba(224, 138, 68, 0.12);
    flex-shrink: 0;
  }
  .pin-list strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.05rem;
    color: var(--ink-50);
  }
  .pin-list small {
    font-size: 0.78rem;
    color: var(--fg-dim);
    letter-spacing: 0.05em;
  }

  /* ── Map ───────────────────────────────────────────────── */
  .region-map {
    aspect-ratio: 1 / 1;
    max-width: 620px;
    margin-left: auto;
    width: 100%;
  }
  .map {
    position: relative;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 50% 50%, rgba(224, 138, 68, 0.06) 0%, transparent 60%),
      radial-gradient(circle at 30% 40%, rgba(90, 115, 96, 0.05), transparent 50%);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .map-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(244,237,227,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244,237,227,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .center-pin {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    color: var(--ember-400);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    z-index: 3;
  }
  .center-pin svg {
    width: 50px; height: 50px;
    animation: breathe 4s ease-in-out infinite;
  }
  @keyframes breathe {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.08); opacity: 0.85; }
  }
  .center-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1rem;
    color: var(--ember-300);
    letter-spacing: 0.05em;
  }

  .pin {
    position: absolute;
    top: var(--y); left: var(--x);
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
    z-index: 2;
    animation: fade-in 0.9s var(--ease) var(--d) backwards;
  }
  @keyframes fade-in { from { opacity: 0; transform: translate(-50%, -30%); } }
  .pin-marker {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--ink-50);
    border: 2px solid var(--ember-400);
    box-shadow: 0 0 16px rgba(224, 138, 68, 0.6);
  }
  .pin-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--ink-50);
    margin-top: 0.4rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .pin-sub {
    font-size: 0.68rem;
    color: var(--fg-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--ember-400);
    pointer-events: none;
    z-index: 1;
  }

  @media (max-width: 900px) {
    .region-grid { grid-template-columns: 1fr; }
    .region-map { max-width: 100%; }
    .pin-list { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .pin-list { grid-template-columns: 1fr; }
  }
</style>
