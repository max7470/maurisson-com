---
import { type Lang, languages, hubUrl } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const langHref = (l: string) => hubUrl(l as Lang);
---
<nav data-nav class="navhub">
  <div class="nav-inner">
    <a href={hubUrl(lang)} class="brand" aria-label="Maurisson">
      <span class="brand-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 11.5 12 4l9 7.5"/>
          <path d="M5 10v10h14V10"/>
          <path d="M10 20v-6h4v6"/>
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-chez">Chez</span>
        <span class="brand-name">Maurisson</span>
      </span>
    </a>

    <div class="lang-switch" aria-label="Language">
      {Object.entries(languages).map(([code, label]) => (
        <a
          href={langHref(code)}
          class={'lang' + (lang === code ? ' active' : '')}
          aria-current={lang === code ? 'page' : undefined}
        >{label}</a>
      ))}
    </div>
  </div>
</nav>

<style>
  nav.navhub {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    padding: 1.2rem var(--gutter);
    transition: all var(--dur) var(--ease);
    background: rgba(11, 9, 7, 0.4);
    backdrop-filter: blur(12px) saturate(130%);
    border-bottom: 1px solid rgba(244, 237, 227, 0.04);
  }
  nav.navhub.scrolled {
    padding-block: 0.8rem;
    backdrop-filter: blur(20px) saturate(155%);
    background: rgba(11, 9, 7, 0.8);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--fg);
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.01em;
    font-size: 1.1rem;
    line-height: 1;
  }
  .brand-mark {
    width: 60px; height: 60px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--ember-400);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    transition: all var(--dur) var(--ease);
  }
  .brand-mark svg { width: 30px; height: 30px; }
  .brand:hover .brand-mark {
    background: var(--ember-500);
    color: var(--ink-950);
    border-color: var(--ember-500);
    transform: rotate(-6deg);
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1; }
  .brand-chez {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: var(--fg-dim);
    letter-spacing: 0.05em;
    margin-bottom: 3px;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.9rem;
    letter-spacing: -0.01em;
  }

  .lang-switch {
    display: flex;
    gap: 0.2rem;
    align-items: center;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
  }
  .lang-switch .lang {
    padding: 0.45rem 0.7rem;
    color: var(--fg-dim);
    border-radius: 6px;
    font-weight: 500;
    transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .lang-switch .lang:hover {
    color: var(--ember-300);
    background: rgba(244, 237, 227, 0.04);
  }
  .lang-switch .lang.active {
    color: var(--ember-400);
  }

  @media (max-width: 560px) {
    nav.navhub { padding: 0.9rem var(--gutter); }
    .brand { gap: 0.6rem; }
    .brand-mark { width: 44px; height: 44px; }
    .brand-mark svg { width: 22px; height: 22px; }
    .brand-name { font-size: 1.35rem; }
    .brand-chez { font-size: 0.78rem; margin-bottom: 2px; }
    .lang-switch .lang { padding: 0.35rem 0.5rem; }
  }
  @media (max-width: 380px) {
    .brand-chez { display: none; }
  }
</style>
