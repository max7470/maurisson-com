---
import { useTranslations, type Lang, AIRBNB_URL, WHATSAPP, WHATSAPP_URL } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---
<section class="cta">
  <div class="cta-bg">
    <img src="/photos/09-terrasse.avif" alt="" loading="lazy" />
    <div class="cta-overlay"></div>
  </div>

  <div class="container">
    <div class="cta-inner">
      <h2 class="cta-title display reveal">
        <span class="line">{t('cta.title')}</span>
      </h2>
      <p class="cta-body reveal delay-1">{t('cta.body')}</p>
      <div class="cta-actions reveal delay-2">
        <a href={AIRBNB_URL} target="_blank" rel="noopener" class="btn btn--primary btn--lg">
          {t('cta.button')}
          <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="whats">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.6-2.1-.2-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.2-.5 0-.2 0-.4-.1-.5-.1-.2-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.6s1.1 3 1.2 3.2c.2.2 2.2 3.3 5.3 4.7 1.8.8 2.5.8 3.4.7.5-.1 1.8-.7 2-1.4.2-.7.2-1.3.2-1.4-.2-.2-.4-.3-.7-.4zM12 2.5C6.8 2.5 2.5 6.8 2.5 12c0 1.7.5 3.3 1.3 4.7L2.5 21.5l4.9-1.3c1.3.7 2.9 1.1 4.6 1.1 5.2 0 9.5-4.3 9.5-9.5S17.2 2.5 12 2.5z"/></svg>
          <span>{t('cta.whatsapp')}</span>
          <span class="whats-num">{WHATSAPP}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    padding-block: clamp(6rem, 12vw, 12rem);
    overflow: hidden;
    isolation: isolate;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .cta-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.4) saturate(0.85);
  }
  .cta-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, rgba(11,9,7,0.55), rgba(11,9,7,0.95)),
      linear-gradient(180deg, rgba(11,9,7,0.7), rgba(18,15,12,0.95));
  }
  .cta-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .cta-title {
    font-size: clamp(2.6rem, 1.8rem + 4.5vw, 5.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1.8rem;
  }
  .cta-title .line {
    background: linear-gradient(95deg, var(--ink-50) 0%, var(--ember-300) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cta-body {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.1rem, 0.9rem + 0.5vw, 1.4rem);
    color: var(--ink-100);
    margin-bottom: 3rem;
    max-width: 46ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.45;
    letter-spacing: -0.01em;
  }
  .cta-actions {
    display: inline-flex;
    flex-direction: column;
    gap: 1.2rem;
    align-items: center;
  }
  .whats {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--fg-muted);
    font-size: 0.92rem;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    transition: color var(--dur-fast) var(--ease);
  }
  .whats:hover { color: var(--ember-300); }
  .whats svg { color: var(--ember-400); }
  .whats-num {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ember-300);
  }

  @media (max-width: 600px) {
    .whats { flex-wrap: wrap; justify-content: center; gap: 0.4rem; font-size: 0.85rem; }
  }
</style>
