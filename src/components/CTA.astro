---
import { useTranslations, type Lang, AIRBNB_URL } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---
<section class="cta">
  <div class="cta-bg">
    <img src="/photos/09-terrasse.avif" alt="" loading="lazy" />
    <div class="cta-overlay"></div>
  </div>

  <div class="container">
    <div class="cta-inner">
      <h2 class="cta-title display reveal">
        <span class="line">{t('cta.title')}</span>
      </h2>
      <p class="cta-body reveal delay-1">{t('cta.body')}</p>
      <div class="cta-actions reveal delay-2">
        <a href={AIRBNB_URL} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
          {t('cta.button')}
          <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="mailto:contact@maurisson.com" class="whats">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          <span>{t('cta.email')}</span>
          <span class="whats-num">contact@maurisson.com</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    padding-block: clamp(6rem, 12vw, 12rem);
    overflow: hidden;
    isolation: isolate;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .cta-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.4) saturate(0.85);
  }
  .cta-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, rgba(11,9,7,0.55), rgba(11,9,7,0.95)),
      linear-gradient(180deg, rgba(11,9,7,0.7), rgba(18,15,12,0.95));
  }
  .cta-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .cta-title {
    font-size: clamp(2.6rem, 1.8rem + 4.5vw, 5.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1.8rem;
  }
  .cta-title .line {
    background: linear-gradient(95deg, var(--ink-50) 0%, var(--ember-300) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cta-body {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.1rem, 0.9rem + 0.5vw, 1.4rem);
    color: var(--ink-100);
    margin-bottom: 3rem;
    max-width: 46ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.45;
    letter-spacing: -0.01em;
  }
  .cta-actions {
    display: inline-flex;
    flex-direction: column;
    gap: 1.2rem;
    align-items: center;
  }
  .whats {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--fg-muted);
    font-size: 0.92rem;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    transition: color var(--dur-fast) var(--ease);
  }
  .whats:hover { color: var(--ember-300); }
  .whats svg { color: var(--ember-400); }
  .whats-num {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ember-300);
  }

  @media (max-width: 600px) {
    .whats { flex-wrap: wrap; justify-content: center; gap: 0.4rem; font-size: 0.85rem; }
  }
</style>
